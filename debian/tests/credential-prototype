#!/bin/sh
set -e

PROTO_UUID="6ba7b814-9dad-11d1-80b4-00c04fd430c8"

output=$(multiflexi-cli credential-prototype:get --uuid="$PROTO_UUID")

echo "$output" | grep -q "mserver" || { echo "FAIL: 'mserver' code not found in output"; exit 1; }
echo "$output" | grep -q "Stormware Pohoda" || { echo "FAIL: 'Stormware Pohoda' name not found in output"; exit 1; }

echo "OK: mserver credential prototype found"
